{
  "name": "api",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bunx tsc && bunx tsc-alias -p tsconfig.json",
    "start": "bun dist/server.js",
    "lint": "bunx eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "typecheck": "bunx tsc --noEmit && bunx tsc --noEmit -p tsconfig.test.json",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "fastify": "^5.9.0",
    "fastify-type-provider-zod": "^7.0.0",
    "mongodb": "6.21.0",
    "resend": "^6.16.0",
    "shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.2.2"
  }
}
